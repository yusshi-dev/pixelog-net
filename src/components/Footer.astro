---
const platform = "github";
const username = "withastro";
---
<footer>
  <div class="footer-inner">
    <span class="footer-copy">© {new Date().getFullYear()} Pixelog</span>
    <div class="footer-icons">
      <a class="footer-icon" href="/atom.xml" title="RSS">
        <svg viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
      </a>
      <a class="footer-icon" href="https://github.com/yusshi-dev" title="GitHub">
        <svg viewBox="0 0 24 24"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
      </a>
      <a class="footer-icon" href="https://x.com/yussious" title="Twitter / X">
        <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  /* ─── Footer ─── */
  footer {
    border-top: 1px solid var(--line);
  }
  .footer-inner {
    max-width: var(--max-w); margin: 0 auto;
    padding: 1.2rem var(--pad);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.75rem;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6rem; letter-spacing: 0.08em;
    color: var(--ink-mute);
  }
  .footer-icons { display: flex; gap: 0.5rem; align-items: center; }
  .footer-icon {
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--line-strong);
    border-radius: 6px;
    color: var(--ink-sub); text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .footer-icon:hover { border-color: var(--ink); color: var(--ink); }
  .footer-icon svg { width: 13px; height: 13px; fill: currentColor; }
</style>
