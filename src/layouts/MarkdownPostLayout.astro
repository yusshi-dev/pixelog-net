---
import BaseLayout from "./BaseLayout.astro";
import { formatDateYear, formatISODatetime } from '../utils/datetime';
const { frontmatter } = Astro.props;
---
<BaseLayout pageTitle={frontmatter.title}>
  <a class="back-link" href="/posts/">← Posts</a>
  <article>
    <div class="article-header">
        <div class="article-meta-row">
        <time class="article-date" datetime={formatISODatetime(frontmatter.date)}>
          {formatDateYear(frontmatter.date)}
        </time>
        <span class="article-cat-badge">{frontmatter.category}</span>
        </div>
        <h1 class="article-h1">{frontmatter.title}</h1>
    </div>

    <div class="article-body">
      <slot />
    </div>

    {
        frontmatter.tags?.length > 0 && (
            <div class="tags-row">
                <span class="tags-label">Tags</span>
                {
                    frontmatter.tags.map((tag: string) => (
                        <a href={`/tags#${tag}`} class="tag">{tag}</a>
                    ))
                }
            </div>
        )
    }


  </article>
</BaseLayout>

<style>
/* ═══════════════════════════════
     ARTICLE PAGE
  ═══════════════════════════════ */
  .back-link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.63rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-light);
    background: none; border: none; cursor: pointer;
    padding: 0; margin-top: 2.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent-alt); }

  .article-header { margin: 2rem 0 2.5rem; }
  .article-meta-row {
    font-family: var(--font-mono);
    font-size: 0.63rem; letter-spacing: 0.1em;
    color: var(--ink-faint);
    display: flex; gap: 1rem; margin-bottom: 1rem;
    flex-wrap: wrap; align-items: center;
  }
  .article-cat-badge {
    color: var(--accent-alt);
    border: 1px solid currentColor;
    padding: 0.15em 0.6em; border-radius: 100px;
    font-size: 0.58rem;
  }
  .article-h1 {
    font-family: var(--font-ja);
    font-size: clamp(1.2rem, 3.5vw, 1.65rem);
    font-weight: 500; line-height: 1.55;
    color: var(--ink); letter-spacing: 0.01em;
  }

  .article-body {
    font-size: 0.95rem; line-height: 2.05;
    color: var(--ink); font-weight: 300;
  }

  .tags-row {
    margin-top: 2.5rem; padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center;
  }
  .tags-label {
    font-family: var(--font-mono);
    font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-faint); margin-right: 0.2rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.62rem; letter-spacing: 0.06em;
    border: 1px solid var(--line-strong);
    padding: 0.25em 0.75em; border-radius: 100px;
    color: var(--ink-mid);
    transition: border-color 0.2s, color 0.2s;
    text-decoration: none;
  }
  .tag:hover { border-color: var(--ink-light); color: var(--ink); }
</style>

<style is:global>
  .article-body p { margin-bottom: 1.5em; }
  .article-body h2 {
    font-family: var(--font-ja);
    font-size: 1rem; font-weight: 500;
    color: var(--ink);
    margin: 2.2em 0 0.75em;
  }
  .article-body code {
    font-family: var(--font-mono);
    font-size: 0.8em;
    background: var(--bg-2);
    border: 1px solid var(--line-strong);
    padding: 0.15em 0.45em; border-radius: 4px;
    color: var(--accent-alt);
  }
  .article-body pre {
    background: var(--ink);
    color: #d4cfcb;
    padding: 1.25rem 1.4rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.8em 0;
    font-family: var(--font-mono);
    font-size: 0.8rem; line-height: 1.75;
  }
  .article-body pre code {
    background: none; border: none; padding: 0; color: inherit; font-size: 1em;
  }
  .article-body blockquote {
    border-left: 2px solid var(--ink-faint);
    padding: 0.2em 1.2em;
    color: var(--ink-light);
    font-style: italic; margin: 1.8em 0;
  }
  .article-body img {
    max-width: 100%;
    height: auto;
    border-radius: .5rem;
  }
</style>